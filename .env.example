# Frontend app URL (used for payment redirects and links)
VITE_FRONTEND_URL=http://localhost:5174

# Backend API base URL.
# Option A (recommended with vite proxy): /api
# Option B (direct backend): http://localhost:5000/api
# In development, the app forces /api to use Vite proxy and avoid browser CORS issues.
VITE_API_BASE_URL=/api

# Backend create-order endpoint path (relative to VITE_API_BASE_URL)
# Example final URL: /api/orders
VITE_ORDER_CREATE_PATH=/orders

# Checkout order currency
VITE_ORDER_CURRENCY=USD

# Stripe publishable key (optional unless Stripe flow is enabled)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_key

# Backend image host (used by product image utils)
VITE_BACK_END_URL=http://localhost:5000
